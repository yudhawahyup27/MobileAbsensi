<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/splashScreen">

    <fragment
        android:id="@+id/splashScreen"
        android:name="com.nairobi.tugasakhir.SplashScreen"
        android:label="fragment_splash_screen"
        tools:layout="@layout/fragment_splash_screen" >
        <action
            android:id="@+id/action_splashScreen_to_homepageAdmin"
            app:destination="@id/homepageAdmin" />
    </fragment>
    <fragment
        android:id="@+id/homepageAdmin"
        android:name="com.nairobi.tugasakhir.admin.HomepageAdmin"
        android:label="fragment_homepage_admin"
        tools:layout="@layout/fragment_homepage_admin" />
</navigation>